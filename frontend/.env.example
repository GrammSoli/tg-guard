# Frontend env vars are read at BUILD time by Vite. After editing,
# rebuild the frontend: `docker compose up -d --build frontend-build`.
#
# All vars are optional — the app boots without any of them, just with
# reduced functionality (no error reporting, no brand logos, etc.).

# Sentry error + replay reporting. Leave unset for local dev.
VITE_SENTRY_DSN=

# Stamped into every Sentry event so dashboards can group by release.
VITE_APP_VERSION=

# Telegram bot username (without @) used to build invite links of the
# form https://t.me/<username>?startapp=room_<code>.
VITE_BOT_USERNAME=SubGuardBot

# Optional support contact URL appended to the Settings page. Empty
# value hides the button.
VITE_SUPPORT_URL=

# Brandfetch Logo Link clientId. Without it ServiceLogo falls back to
# a colored first-letter placeholder for every brand — the app still
# works, just no nice logos. Register at developers.brandfetch.com
# for a free 500k-req/month tier (no attribution required).
VITE_BRANDFETCH_CLIENT_ID=
